{
  "name": "security-update/security-update-repo-php",
  "description": "Intentionally vulnerable PHP sample project for Dependabot alert testing",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^7.4 || ^8.0",
    "symfony/http-foundation": "2.7.0",
    "twig/twig": "1.20.0",
    "guzzlehttp/guzzle": "7.11.0"
  },
  "autoload": {
    "psr-4": {
      "SecurityUpdateRepoPhp\\": "src/"
    }
  },
  "config": {
    "platform": {
      "php": "7.4.0"
    },
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
